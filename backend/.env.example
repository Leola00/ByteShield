OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Optional — defaults to OPENAI_MODEL; use gpt-4o for higher vision accuracy
OPENAI_VISION_MODEL=gpt-4o-mini
# SOC incident report model (backend/app.py)
OPENAI_SOC_MODEL=gpt-4o-mini
PORT=3000
# Python ML inference + SOC reports
# Windows: PYTHON_BIN=py and PYTHON_ARGS=-3
# Linux/macOS: PYTHON_BIN=python3 and leave PYTHON_ARGS empty
PYTHON_BIN=py
PYTHON_ARGS=-3

# Supabase (Fraud Operations live storage)
# Project URL + keys from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-or-secret-key
